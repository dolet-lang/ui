# ============================
#  Dolet Native UI Library
# ============================
# Pure software 2D drawing + UI infrastructure.
# Drawing: zero OS calls in the draw layer; one blit per frame for present.
# Also provides: draw command recording, mouse input, rect helpers.
module ui
import window
import fonts

load ui/types
load ui/color
load ui/bindings/win32
load ui/canvas
load ui/input
load ui/commands

