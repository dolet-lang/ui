# UI Module Metadata
# Pure software UI + 2D drawing library for Dolet.

[info]
name = ui
version = 0.6.0
description = Pure-Dolet drawing + UI library. Zero Win32 externs in this package — window does the platform work. Framebuffer canvas, bitmap text, draw command recording, mouse input.

[dependencies]
window
fonts
input

[link.windows]
# None — window provides the Win32 linking.

[link.linux]
# Planned later.

[link.baremetal]
# No system libs needed.
