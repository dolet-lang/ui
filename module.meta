# UI Module Metadata
# UI-layer infrastructure on top of draw.

[info]
name = ui
version = 0.3.0
description = UI infrastructure: draw command recording, mouse input, rect helpers. Drawing itself lives in `draw`.

[dependencies]
draw

[link.windows]
# None needed — user32/gdi32 are pulled in via draw.

[link.linux]
# Planned later.

[link.baremetal]
# No system libs needed.
